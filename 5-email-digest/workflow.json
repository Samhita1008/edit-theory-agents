        "jsCode": "const skipDomains = ['noreply', 'newsletter', 'notifications', 'marketing', 'no-reply'];\n\nreturn items.filter(item => {\n  const from = (item.json.From || '').toLowerCase();\n  return !skipDomains.some(pattern => from.includes(pattern));\n});"
