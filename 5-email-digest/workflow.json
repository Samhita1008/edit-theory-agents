    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"llama-3.3-70b-versatile\",\n  messages: [\n    {\n      role: \"system\",\n      content: \"You are an email triage assistant. Respond ONLY with valid JSON, no markdown fences, no preamble. Format: {\\\"priority\\\": \\\"🔴\\\" | \\\"🟡\\\" | \\\"🟢\\\", \\\"summary\\\": \\\"one line, max 15 words\\\", \\\"reason\\\": \\\"why this priority, max 8 words\\\"}. 🔴 = needs reply today. 🟡 = FYI, no action needed. 🟢 = can wait.\"\n    },\n    {\n      role: \"user\",\n      content: \"From: \" + $json.From + \"\\nSubject: \" + $json.Subject + \"\\nBody: \" + $json.snippet\n    }\n  ],\n  temperature: 0.3\n}) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        640,
        0
      ],
      "id": "79281b22-b286-4a63-9d90-8b43e2b40f8a",
      "name": "HTTP Request",
      "credentials": {
        "httpHeaderAuth": {
          "id": "SZcLaO9JSfMYRtuf",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return items.map((item) => {\n  const raw = item.json.choices[0].message.content;\n  const clean = raw.replace(/```json|```/g, '').trim();\n  const parsed = JSON.parse(clean);\n\n  const originalIndex = item.pairedItem.item;\n  const original = $('Get many messages').all()[originalIndex].json;\n\n  return {\n    json: {\n      from: original.From,\n      subject: original.Subject,\n      priority: parsed.priority,\n      summary: parsed.summary,\n      reason: parsed.reason\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        0
      ],
      "id": "56d4231e-c262-42f0-a6f0-361b9e5d37d2",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const items_in = items;\n\nconst order = { '🔴': 0, '🟡': 1, '🟢': 2 };\nitems_in.sort((a, b) => order[a.json.priority] - order[b.json.priority]);\n\nlet message = `📬 *Morning Digest — ${new Date().toDateString()}*\\n\\n`;\n\nconst counts = { '🔴': 0, '🟡': 0, '🟢': 0 };\nitems_in.forEach(item => counts[item.json.priority]++);\nmessage += `${counts['🔴']} need reply · ${counts['🟡']} FYI · ${counts['🟢']} can wait\\n\\n`;\n\nitems_in.forEach(item => {\n  const { priority, from, subject, summary } = item.json;\n  const fromName = from.split('<')[0].trim();\n  message += `${priority} *${fromName}*\\n${summary}\\n\\n`;\n});\n\nreturn [{ json: { message } }];"
      },
