    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst result = [];\n\nfor (const item of items) {\n  let dateSent = String(item.json['Date Sent']);\n  let today = new Date();\n  today.setHours(0,0,0,0);\n  \n  let diffDays = 0;\n  \n  let day = parseInt(dateSent.substring(0, 2));\n  let month = parseInt(dateSent.substring(3, 5)) - 1;\n  let year = parseInt(dateSent.substring(6, 10));\n  \n  let parsedDate = new Date(year, month, day);\n  parsedDate.setHours(0,0,0,0);\n  \n  diffDays = Math.round((today - parsedDate) / 86400000);\n  \n  result.push({\n    json: {\n      ...item.json,\n      daysSinceSent: diffDays,\n      sendFollowUp1: diffDays >= 3 && diffDays < 7,\n      sendFollowUp2: diffDays >= 7 && diffDays < 14,\n      sendFollowUp3: diffDays >= 14\n    }\n  });\n}\n\nreturn result;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
