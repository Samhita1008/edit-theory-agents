    {
      "parameters": {
        "jsCode": "const gmailMessages = $('Get many messages').all();\nconst sheetRows = items;\n\nconst matched = [];\n\nfor (const msg of gmailMessages) {\n  const fromEmail = msg.json.From.match(/<(.+)>/)?.[1] || msg.json.From;\n\n  const matchingRow = sheetRows.find(row => row.json.Email === fromEmail);\n\n  if (matchingRow) {\n    matched.push({\n      json: {\n        rowNumber: matchingRow.json.row_number,\n        name: matchingRow.json.Name,\n        email: fromEmail,\n        replySnippet: msg.json.snippet,\n        subject: msg.json.Subject,\n        currentStatus: matchingRow.json.Status || ''\n      }\n    });\n  }\n}\n\nreturn matched;"
      },
